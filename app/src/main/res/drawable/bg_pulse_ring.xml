<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Ring -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#302196F3" />
            <size android:width="60dp" android:height="60dp" />
        </shape>
    </item>
    <!-- Middle Ring -->
    <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#602196F3" />
        </shape>
    </item>
    <!-- Inner Solid (Optional, can be faint) -->
    <item android:top="16dp" android:left="16dp" android:right="16dp" android:bottom="16dp">
        <shape android:shape="oval">
            <solid android:color="#152196F3" />
        </shape>
    </item>
</layer-list>